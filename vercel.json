{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "excludeFiles": "{.git/**,assets/**,forms/**,src/**,*.html,bower.json,package.json,package-lock.json,tipso.jquery.json,.travis.yml}"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/index.php",
      "destination": "/index.html"
    }
  ]
}
