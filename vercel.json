{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "excludeFiles": "{.git/**,assets/**,forms/**,src/**,*.html,bower.json,package.json,package-lock.json,tipso.jquery.json,.travis.yml}"
    }
  },
  "rewrites": [
    {
      "source": "/i-nostri-eventi",
      "destination": "/inner-page.html"
    },
    {
      "source": "/dove-operiamo",
      "destination": "/dove-operiamo.html"
    },
    {
      "source": "/attestati",
      "destination": "/ringraziamenti.html"
    },
    {
      "source": "/pensieri",
      "destination": "/pensieri.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/index.php",
      "destination": "/index.html"
    }
  ]
}
